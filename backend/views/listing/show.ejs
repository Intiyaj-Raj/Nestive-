<% layout("/layouts/boilerplate") %>

  <div class="row">
    <div class="col-8 offset-3 mb-3">
      <h3>
        <%= listing.title %>
      </h3>
    </div>
    <div class="card col-6 offset-3 show-card">
      <img src="<%= listing.image %>" class="card-img-top show-img" alt="listing_image" />
      <div class="card-body mt-3">
        <p class="card-text">
          <%= listing.description %> <br />
            <%= listing.price.toLocaleString("en-IN") %> <br />
              <%= listing.location%> <br />
                <%= listing.country%> <br />
        </p>
      </div>
    </div>

    <br />
  </div>
  <div class="btns">
    <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-3 edit-btn">Edit</a>
    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
      <button class="btn btn-dark offset-5">Delete</button>
    </form>
  </div>

  <div class="col-8 offset-3 mb-3">
    <hr>
    <h3>Leave a Review</h3>
    <form method="POST" action="/listings/<%= listing._id %>/reviews">
      <div class="mb-3 mt-3">
        <label for="rating">Rating</label>
        <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-control" />
      </div>

      <div class=" mb-3 mt-3 ">
        <label for="comment">Comments</label>
        <textarea name="review[comment]" id="comment" cols="30" rows="3" class="form-control"></textarea>
      </div>
      <button class="btn btn-outline-dark">Submit</button>
    </form>
    <hr>
    <h4>All Reviews</h4>
    <div class="row">
      <% for(let review of listing.reviews){ %>
        <div class="card col-5 ms-3 mb-3 p-3">
          <div class="card-body">
            <h5 class="card-title">Intiyaj Raj</h5>
            <p class="card-text">
              <%= review.comment %>
            </p>
            <p class="card-text">
              <%= review.rating %> stars
            </p>
          </div>
          <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
            <button class="btn btn-danger mt-4">Delete</button>
          </form>
        </div>
        <% } %>
    </div>

  </div>